// test_fs.wh
import "std/fs" as fs;

fn main() -> Result<int> {
    print("Testing write_string...");
    // Using the ? operator safely extracts the value or early returns the error
    let written = fs.write_string("test_output.txt", "Hello, Whale File System!")?;
    print("Bytes written: " + to_string(written));
    
    print("Testing read_to_string...");
    let content = fs.read_to_string("test_output.txt")?;
    print("File Content: " + content);
    
    print("Testing Error Handling (File Not Found)...");
    let err_result = fs.read_to_string("non_existent_file.txt");
    
    // We expect this to be an error! 
    // We can safely propagate it up using the ? operator, or just ignore it.
    
    return Ok(0);
}

main();
