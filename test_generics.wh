// test_generics.wh
pub struct List<T> {
    data: int,
    len: int,
}

pub fn identity<T>(value: int) -> int {
    return value;
}

pub trait Stringer {
    fn to_string() -> string;
}

pub impl Stringer for List {
    fn to_string() -> string {
        return "List";
    }
}

fn main() {
    print("Parsing generics test");
}

main();
