{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Whale",
  "scopeName": "source.wh",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#functions" },
    { "include": "#builtins" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.wh",
      "match": "//.*$"
    },
    "keywords": {
      "name": "keyword.control.wh",
      "match": "\\b(fn|let|mut|if|else|while|for|in|return|struct|match|import|and|or|not)\\b"
    },
    "types": {
      "name": "storage.type.wh",
      "match": "\\b(int|float|string|bool|void)\\b"
    },
    "strings": {
      "name": "string.quoted.double.wh",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.wh", "match": "\\\\." }
      ]
    },
    "numbers": {
      "name": "constant.numeric.wh",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "booleans": {
      "name": "constant.language.wh",
      "match": "\\b(true|false)\\b"
    },
    "functions": {
      "name": "entity.name.function.wh",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
    },
    "builtins": {
      "name": "support.function.wh",
      "match": "\\b(print|len|to_string|contains|read_file|write_file|lines|split|trim|replace|to_lower|to_upper|abs|max|min|parse_int|type_of|push|pop|stream|map|filter|collect|for_each|fold|take|skip)\\b"
    }
  }
}
