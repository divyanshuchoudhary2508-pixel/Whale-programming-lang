// test_error.wh

pub fn might_fail(fail: bool) -> Result<int> {
    if fail {
        return error("it failed!");
    }
    return 42;
}

pub fn do_something(fail: bool) -> Result<int> {
    let val = might_fail(fail)?;
    return val + 10;
}

fn main() {
    let res1 = do_something(false);
    print("res1 (Success): ");
    print(res1);
    
    let res2 = do_something(true);
    print("res2 (Failure): ");
    print(res2);
}

main();
