import "std/memory";
import "std/string";
import "std/fs";
import "std/net";
import "std/time";
import "std/thread";
import "std/sync";
import "std/json";
import "std/http";

extern fn my_thread_func(arg: int) -> int;

fn main() {
    let msg = "Whale C-FFI is incredibly fast and memory safe!";
    
    let length = string.len(msg);
    print(length); // Output length of string

    // Test memory
    let ptr = memory.alloc(length + 1);
    if ptr != 0 {
        print(ptr); // should print memory address
        memory.dealloc(ptr);
    }
    
    // Test fs
    let file = fs.open("test_output.txt", "w");
    if file != 0 {
        print(file); // should print file descriptor/pointer
        fs.close(file);
    }
    
    // Test time
    let current_time = time.now();
    print(current_time);
    
    // Test net
    // AF_INET = 2, SOCK_STREAM = 1, IPPROTO_TCP = 6
    let sockfd = net.create_socket(2, 1, 6);
    if sockfd != 0 {
        print(sockfd);
        // We'd close it with close(sockfd) from unistd but let's just test creation
    }
    
    // Test concurrency
    let mut m = sync.new_mutex();
    sync.lock(m);
    sync.unlock(m);
    print("Mutex initialized and tested");
    
    let arg = 42;
    // We cannot easily pass a function pointer in this basic test without a real C function,
    // but we'll just test that the compiler can resolve `thread.spawn`.
    // let t = thread.spawn(my_thread_func, &arg);
    // thread.join(t);

    // Test JSON
    let j_str = json.new_string("hello JSON");
    let encoded = json.encode(j_str);
    print(encoded);

    // Test HTTP
    let resp = http.get("http://example.com");
    print(resp.status_code);
    
    let server = http.listen(8080);
    http.close(server);

    print("Standard library tests completed successfully.");
}

main();
