// arithmetic.wh — tests arithmetic operators and precedence.
// Expected output:
//   13
//   7
//   30
//   3
//   1
//   5.5
//   true
//   false
//   true

let a = 10;
let b = 3;
print(a + b);        // 13
print(a - b);        // 7
print(a * b);        // 30
print(a / b);        // 3 (integer division)
print(a % b);        // 1

// Float arithmetic
let f = 5.5;
print(f);            // 5.5

// Comparison
print(a > b);        // true
print(a < b);        // false
print(a >= 10);      // true

// Operator precedence
let result = 2 + 3 * 4;  // = 14
let result2 = (2 + 3) * 4; // = 20
print(result);
print(result2);
